# Copie para .env e ajuste os valores.
# cp .env.example .env
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=sistema_pequena_empresa

JWT_SECRET=altere_para_um_segredo_longo_em_producao
JWT_EXPIRES_SEGUNDOS=604800

# Backend NestJS (evitar conflito com Next.js na 3000)
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Apenas desenvolvimento: echo SQL no console
TYPEORM_LOGGING=false

# Não use synchronize em produção. O protótipo espera schema criado por ../banco.sql
TYPEORM_SYNC=false

# Opcional (Docker / rede lenta): tentativas de conexão ao PostgreSQL
# DATABASE_RETRY_ATTEMPTS=20
# DATABASE_RETRY_DELAY_MS=3000
